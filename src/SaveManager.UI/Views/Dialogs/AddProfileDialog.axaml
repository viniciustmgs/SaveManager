<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SaveManager.UI.ViewModels.Dialogs"
        xmlns:material="using:Material.Icons.Avalonia"
        x:Class="SaveManager.UI.Views.Dialogs.AddProfileDialog"
        x:DataType="vm:AddProfileDialogViewModel"
        Title="Add Profile"
        Width="300"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="#282828">

    <StackPanel Margin="16" Spacing="12">

        <!-- name -->
        <StackPanel Spacing="4">
            <TextBlock Text="Name:" />
            <TextBox Text="{Binding Name}" />
        </StackPanel>

        <!-- buttons -->
        <Grid Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Width="110"
                    Command="{Binding CancelCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <material:MaterialIcon Kind="Close" Width="16" Height="16" Foreground="#F44336" />
                    <TextBlock Text="Cancel" />
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Width="110"
                    IsEnabled="{Binding CanAddProfile}"
                    Command="{Binding AddProfileCommand}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <material:MaterialIcon Kind="Plus" Width="16" Height="16" Foreground="#4CAF50" />
                    <TextBlock Text="Add Profile" />
                </StackPanel>
            </Button>
        </Grid>

    </StackPanel>
</Window>